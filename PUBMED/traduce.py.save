




























from deep_translator import GoogleTranslator

file = 'built_environments_may0626.txt'

fil = open(file,'r')

datos = fil.readlines()

traductor = GoogleTranslator(source='en', target='es')

k = 1
for ss in datos:
  ss = ss.replace('\n','')
  ss = ss[6:]
  if len(ss) > 10:
    print(str(k) + ' - ' + ss+'\n')
    ss2 = traductor.translate(ss)
    print(ss2+'\n')
    k = k+1

